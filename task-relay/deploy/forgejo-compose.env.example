# Forgejo Docker Compose runtime variables.
# Local-host example: copy to /etc/task-relay/forgejo-compose.env and edit as needed.

# Pin an explicit Forgejo image tag.
FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:15.0.0

# Public URL users will open in the browser.
# Local example: Forgejo runs on the same host and is opened directly on port 3000.
FORGEJO_ROOT_URL=http://127.0.0.1:3000/

# Container runtime uid/gid.
FORGEJO_UID=1000
FORGEJO_GID=1000

# Host ports to publish for local use.
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=222
