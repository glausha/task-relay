[Unit]
Description=task-relay reconcile pass
After=task-relay-journal-ingester.service
Requires=task-relay-journal-ingester.service

[Service]
Type=oneshot
User=task-relay
EnvironmentFile=/etc/task-relay/task-relay.env
WorkingDirectory=/var/lib/task-relay
ExecStart=/usr/local/bin/task-relay reconcile

