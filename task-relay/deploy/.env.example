# task-relay runtime environment example
# Copy to /etc/task-relay/task-relay.env and edit for your environment.
# Paths are resolved from WorkingDirectory=/var/lib/task-relay in systemd.

# SQLite truth store.
TASK_RELAY_SQLITE_PATH=/var/lib/task-relay/state.sqlite

# Durable ingress journal directory.
TASK_RELAY_JOURNAL_DIR=/var/lib/task-relay/journal

# Compressed tool log output directory.
TASK_RELAY_LOG_DIR=/var/lib/task-relay/logs

# Redis for branch lease and dispatcher coordination.
TASK_RELAY_REDIS_URL=redis://127.0.0.1:6379/0

# Forgejo base URL for issue and label projection.
TASK_RELAY_FORGEJO_BASE_URL=https://forgejo.example.internal

# Forgejo webhook listener host. Keep loopback unless a reverse proxy terminates ingress.
TASK_RELAY_FORGEJO_WEBHOOK_HOST=127.0.0.1

# Forgejo webhook listener port.
TASK_RELAY_FORGEJO_WEBHOOK_PORT=8787

# Forgejo owner or namespace for mirrored issues.
TASK_RELAY_FORGEJO_OWNER=example-org

# Forgejo repository name for mirrored issues.
TASK_RELAY_FORGEJO_REPO=task-relay

# Forgejo API token with issue read/write permission.
TASK_RELAY_FORGEJO_TOKEN=CHANGE_ME

# Forgejo webhook secret used for HMAC verification.
TASK_RELAY_FORGEJO_WEBHOOK_SECRET=CHANGE_ME

# Discord bot token.
TASK_RELAY_DISCORD_BOT_TOKEN=CHANGE_ME

# JSON array of Discord guild IDs allowed to use the bot.
TASK_RELAY_DISCORD_GUILD_IDS=[123456789012345678]

# JSON array of Discord user IDs treated as admins.
TASK_RELAY_ADMIN_USER_IDS=[123456789012345678]

# Breaker rolling window in seconds.
TASK_RELAY_BREAKER_WINDOW_SECONDS=600

# Breaker fatal threshold within the active window.
TASK_RELAY_BREAKER_FATAL_THRESHOLD=3

# Stop accepting new tasks when remaining/limit falls below this ratio.
TASK_RELAY_RATE_STOP_NEW_TASKS_RATIO=0.2

# Initial projection retry backoff in seconds.
TASK_RELAY_PROJECTION_RETRY_INITIAL_SECONDS=60

# Projection retry backoff cap in seconds.
TASK_RELAY_PROJECTION_RETRY_CAP_SECONDS=3600

# Maximum projection attempts before durable degradation handling.
TASK_RELAY_PROJECTION_RETRY_MAX_ATTEMPTS=50

# Projection degradation threshold in hours.
TASK_RELAY_PROJECTION_RETRY_DEGRADE_HOURS=24

# Grace window for implementing resume after cold start.
TASK_RELAY_IMPLEMENTING_RESUME_GRACE_SECONDS=120

# Fresh heartbeat threshold used by reconcile.
TASK_RELAY_IMPLEMENTING_RESUME_HEARTBEAT_SECONDS=60

# SIGTERM grace for child subprocess shutdown.
TASK_RELAY_SUBPROCESS_SIGTERM_GRACE_SECONDS=15

# Root directory for executor worktrees.
TASK_RELAY_EXECUTOR_WORKSPACE_ROOT=/var/lib/task-relay/worktrees

# Planner model identifier.
TASK_RELAY_PLANNER_MODEL=claude-opus-4-6

# Planner max output tokens.
TASK_RELAY_PLANNER_MAX_TOKENS=4096

# Reviewer model identifier.
TASK_RELAY_REVIEWER_MODEL=gpt-5.4

# Executor timeout in seconds.
TASK_RELAY_EXECUTOR_TIMEOUT=600

# Redis lease TTL in seconds.
TASK_RELAY_LEASE_TTL_SECONDS=30

# Redis lease renew cadence in seconds.
TASK_RELAY_LEASE_RENEW_INTERVAL_SECONDS=10

# Journal retention window in days.
TASK_RELAY_JOURNAL_RETAIN_DAYS=30

# Offsite journal retention window in days.
TASK_RELAY_JOURNAL_OFFSITE_RETAIN_DAYS=7

# Full log retention window in days.
TASK_RELAY_LOG_RETAIN_FULL_DAYS=30

# Digest log retention window in days.
TASK_RELAY_LOG_RETAIN_DIGEST_DAYS=180

# Discord ingress writer queue capacity.
TASK_RELAY_DISCORD_WRITER_QUEUE_CAPACITY=1024

# Discord durable-acceptance ack deadline in milliseconds.
TASK_RELAY_DISCORD_ACK_DEADLINE_MS=1500

# Optional Litestream config path for operators and restore tooling.
TASK_RELAY_LITESTREAM_CONFIG_PATH=/etc/task-relay/litestream.yml
